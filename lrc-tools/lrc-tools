#!/usr/bin/env python3
"""lrc-tools — interactive terminal UI. Alias: lt"""
import os
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent
os.environ.setdefault("LRC_TOOLS_REPO", str(REPO))

CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
PKG_ROOT = CONFIG_HOME / "lrc-tools"
INSTALLED_PKG = PKG_ROOT / "lrc_tools"

if INSTALLED_PKG.is_dir() and (INSTALLED_PKG / "tui_main.py").is_file():
    sys.path.insert(0, str(PKG_ROOT))
    from lrc_tools.tui_main import main
else:
    sys.path.insert(0, str(REPO))
    from tui.app import main

if __name__ == "__main__":
    main()
